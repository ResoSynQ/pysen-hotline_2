<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>アンケート | kiiroPAISEN</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Zen+Maru+Gothic:wght@400;700&display=swap" rel="stylesheet">
<style>
  /* ===== CSS Variables ===== */
  :root {
    --bg: #0f0f14;
    --surface: #1a1a24;
    --surface2: #22222f;
    --accent: #f5c842;
    --accent2: #ff7c3f;
    --text: #e8e4d8;
    --text-dim: #8a8478;
    --bubble-ai: #1e2235;
    --bubble-user: #2a1f0e;
    --border: rgba(245,200,66,0.18);
    --glow: rgba(245,200,66,0.25);
    --font-main: 'Zen Maru Gothic', 'Noto Sans JP', sans-serif;
    --radius: 18px;
    --max-turns: 10;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: var(--font-main);
    background: var(--bg);
    color: var(--text);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
  }

  /* ===== Background ===== */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 10%, rgba(245,200,66,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 90%, rgba(255,124,63,0.06) 0%, transparent 70%);
    pointer-events: none; z-index: 0;
  }

  /* ===== Layout ===== */
  #app {
    position: relative; z-index: 1;
    width: 100%; max-width: 680px;
    min-height: 100dvh;
    display: flex; flex-direction: column;
    padding: 0 12px 24px;
  }

  /* ===== Header ===== */
  header {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 4px 10px;
    border-bottom: 1px solid var(--border);
  }
  .header-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.5; transform:scale(.8); }
  }
  .header-title {
    font-size: .8rem; letter-spacing: .12em;
    color: var(--text-dim); text-transform: uppercase;
  }
  .turn-counter {
    margin-left: auto;
    font-size: .75rem; color: var(--text-dim);
    background: var(--surface2);
    padding: 3px 10px; border-radius: 99px;
    border: 1px solid var(--border);
  }
  .turn-counter span { color: var(--accent); font-weight: 700; }

  /* ===== Avatar Area ===== */
  #avatar-area {
    display: flex; flex-direction: column; align-items: center;
    padding: 20px 0 12px;
  }
  .avatar-frame {
    position: relative;
    width: 130px; height: 130px;
  }
  .avatar-frame::before {
    content: '';
    position: absolute; inset: -3px;
    border-radius: 50%;
    background: conic-gradient(var(--accent), var(--accent2), var(--accent));
    animation: spin 4s linear infinite;
    opacity: 0;
    transition: opacity .4s;
  }
  .avatar-frame.speaking::before { opacity: 1; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .avatar-frame::after {
    content: '';
    position: absolute; inset: 1px;
    border-radius: 50%;
    background: var(--bg);
    z-index: 0;
  }
  .avatar-img {
    position: relative; z-index: 1;
    width: 100%; height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: var(--surface2);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    /* JPG画像がある場合: src="./avatar.jpg" に変更 */
  }
  /* 画像がない場合のフォールバック絵文字 */
  .avatar-emoji {
    position: relative; z-index: 1;
    width: 100%; height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #2a2a3a, #1a1a24);
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem;
    border: 2px solid var(--surface2);
  }
  .avatar-name {
    margin-top: 10px;
    font-size: .9rem; font-weight: 700;
    color: var(--accent); letter-spacing: .08em;
  }
  .avatar-status {
    font-size: .72rem; color: var(--text-dim);
    margin-top: 2px; height: 16px;
    transition: opacity .3s;
  }

  /* ===== Chat Window ===== */
  #chat-window {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0 4px;
    display: flex; flex-direction: column; gap: 10px;
    scroll-behavior: smooth;
  }
  #chat-window::-webkit-scrollbar { width: 4px; }
  #chat-window::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 4px; }

  /* ===== Message Bubbles ===== */
  .msg {
    display: flex; gap: 10px; align-items: flex-end;
    animation: msgIn .35s cubic-bezier(.2,.8,.3,1) both;
  }
  @keyframes msgIn {
    from { opacity:0; transform: translateY(12px); }
    to { opacity:1; transform: translateY(0); }
  }
  .msg.ai { flex-direction: row; }
  .msg.user { flex-direction: row-reverse; }

  .msg-avatar {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    background: var(--surface2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    border: 1px solid var(--border);
  }
  .msg.user .msg-avatar {
    background: linear-gradient(135deg, var(--bubble-user), #3a2510);
  }

  .bubble {
    max-width: 78%;
    padding: 11px 15px;
    border-radius: var(--radius);
    line-height: 1.65; font-size: .88rem;
    position: relative;
  }
  .msg.ai .bubble {
    background: var(--bubble-ai);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
  }
  .msg.user .bubble {
    background: var(--bubble-user);
    border: 1px solid rgba(255,124,63,.2);
    border-bottom-right-radius: 4px;
    color: #f0dcc0;
  }

  /* Typing indicator */
  .typing-dots {
    display: flex; gap: 4px; align-items: center;
    padding: 4px 0;
  }
  .typing-dots span {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--text-dim);
    animation: dot .9s ease-in-out infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: .15s; }
  .typing-dots span:nth-child(3) { animation-delay: .3s; }
  @keyframes dot {
    0%,80%,100% { transform:scale(1); opacity:.4; }
    40% { transform:scale(1.3); opacity:1; }
  }

  /* ===== Input Area ===== */
  #input-area {
    padding: 12px 0 0;
    border-top: 1px solid var(--border);
  }
  .input-row {
    display: flex; gap: 8px; align-items: flex-end;
  }
  #text-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--text);
    font-family: var(--font-main);
    font-size: .88rem;
    padding: 12px 16px;
    resize: none; outline: none;
    min-height: 46px; max-height: 120px;
    line-height: 1.5;
    transition: border-color .2s, box-shadow .2s;
    overflow-y: auto;
  }
  #text-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--glow);
  }
  #text-input::placeholder { color: var(--text-dim); }
  #text-input:disabled {
    opacity: .4; cursor: not-allowed;
  }

  .btn {
    width: 46px; height: 46px; border-radius: 13px;
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
    transition: transform .15s, opacity .2s, box-shadow .2s;
    flex-shrink: 0;
  }
  .btn:active { transform: scale(.92); }
  .btn:disabled { opacity: .35; cursor: not-allowed; transform: none !important; }

  #send-btn {
    background: var(--accent);
    color: #1a1000;
    box-shadow: 0 2px 12px rgba(245,200,66,.3);
  }
  #send-btn:hover:not(:disabled) {
    box-shadow: 0 2px 20px rgba(245,200,66,.5);
  }

  #mic-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
  }
  #mic-btn.recording {
    background: rgba(255,60,60,.15);
    border-color: rgba(255,60,60,.5);
    color: #ff4444;
    animation: micPulse 1s ease-in-out infinite;
  }
  @keyframes micPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(255,60,60,.3); }
    50% { box-shadow: 0 0 0 8px rgba(255,60,60,0); }
  }
  #mic-btn:hover:not(:disabled):not(.recording) {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ===== Hint Text ===== */
  .input-hint {
    text-align: center; font-size: .7rem;
    color: var(--text-dim); margin-top: 8px;
  }

  /* ===== End Screen ===== */
  #end-screen {
    display: none;
    flex-direction: column; align-items: center;
    justify-content: center; text-align: center;
    gap: 16px; padding: 40px 20px;
    animation: fadeIn .8s ease both;
  }
  @keyframes fadeIn {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
  }
  #end-screen.visible { display: flex; }
  .end-icon { font-size: 4rem; }
  .end-title {
    font-size: 1.4rem; font-weight: 700;
    color: var(--accent);
  }
  .end-body { font-size: .9rem; color: var(--text-dim); line-height: 1.7; }

  /* ===== Error Toast ===== */
  #toast {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: #3a1515; border: 1px solid rgba(255,80,80,.4);
    color: #ffaaaa; font-size: .8rem;
    padding: 10px 20px; border-radius: 10px;
    opacity: 0; transition: all .3s;
    pointer-events: none; z-index: 100;
    white-space: nowrap;
  }
  #toast.show {
    opacity: 1; transform: translateX(-50%) translateY(0);
  }

  /* ===== Responsive ===== */
  @media (max-width: 480px) {
    .avatar-frame { width: 100px; height: 100px; }
    .bubble { font-size: .84rem; max-width: 85%; }
  }
</style>
</head>
<body>
<div id="app">

  <!-- Header -->
  <header>
    <div class="header-dot"></div>
    <span class="header-title">アンケートセッション</span>
    <div class="turn-counter">ターン <span id="turn-num">0</span> / 10</div>
  </header>

  <!-- Avatar -->
  <div id="avatar-area">
    <div class="avatar-frame" id="avatar-frame">
      <!--
        【画像の設定方法】
        JPG画像（例: avatar.jpg）を同フォルダに置き、
        下の <div class="avatar-emoji"> を削除して
        <img class="avatar-img" src="./avatar.jpg" alt="kiiroPAISEN"> に変更してください
      -->
      <div class="avatar-emoji">🤖</div>
    </div>
    <div class="avatar-name">kiiroPAISEN</div>
    <div class="avatar-status" id="avatar-status">待機中...</div>
  </div>

  <!-- Chat Window -->
  <div id="chat-window"></div>

  <!-- Input Area (hidden when ended) -->
  <div id="input-area">
    <div class="input-row">
      <textarea
        id="text-input"
        placeholder="メッセージを入力、またはマイクボタンで話しかけてください..."
        rows="1"
      ></textarea>
      <button class="btn" id="mic-btn" title="音声入力">🎤</button>
      <button class="btn" id="send-btn" title="送信" disabled>➤</button>
    </div>
    <div class="input-hint">Enterで送信 / Shift+Enterで改行</div>
  </div>

  <!-- End Screen -->
  <div id="end-screen">
    <!--
      【完了画像の設定方法】
      完了画像（例: thankyou.jpg）を同フォルダに置き、
      下の end-icon を <img src="./thankyou.jpg" style="width:200px;border-radius:16px"> に変更
    -->
    <div class="end-icon">🎉</div>
    <div class="end-title">ありがとうございました！</div>
    <div class="end-body">
      アンケートへのご協力、誠にありがとうございます。<br>
      いただいたご意見を活かして、より良い勉強会を目指してまいります。<br>
      またお会いしましょう！
    </div>
  </div>

</div>

<!-- Toast -->
<div id="toast"></div>

<script>
// ============================================================
//  ★★★ 設定 — ここを変更してください ★★★
// ============================================================
const CONFIG = {
  // GAS WebアプリのURLを貼り付けてください
  GAS_URL: "https://script.google.com/macros/s/AKfycbxEMuvHkGPJhzRVWwS7jWuS04vH-HycgLSe2s5c1Vya5a7X9G0N5fPolWaVAPUwBRuc/exec",

  // 最大ターン数
  MAX_TURNS: 10,

  // キャラクター名
  CHARACTER_NAME: "kiiroPAISEN",

  // 最初の挨拶メッセージ（固定）
  OPENING_MESSAGE: "やあ！昨日の勉強会はどうだった？せっかくだから、ちょっと感想を聞かせてよ〜！",

  // 終了メッセージ（固定）
  CLOSING_MESSAGE: "ありがとう！アンケートはこれにて終了！主催者に変わり御礼申し上げます！勉強会に参加いただきまして誠にありがとうございました。アンケートを参考により良い運営を目指していきます！ご不明点があれば先のメールにて返信いただければと思います。また次回の勉強会でお会いしましょう！ではでは！",
};
// ============================================================

// ===== State =====
let turnCount = 0;
let conversationHistory = []; // {role, content}
let isProcessing = false;
let recognition = null;
let isRecording = false;

// ===== DOM =====
const chatWindow = document.getElementById("chat-window");
const textInput = document.getElementById("text-input");
const sendBtn = document.getElementById("send-btn");
const micBtn = document.getElementById("mic-btn");
const turnNum = document.getElementById("turn-num");
const avatarFrame = document.getElementById("avatar-frame");
const avatarStatus = document.getElementById("avatar-status");
const inputArea = document.getElementById("input-area");
const endScreen = document.getElementById("end-screen");
const toast = document.getElementById("toast");

// ===== Init =====
window.addEventListener("DOMContentLoaded", () => {
  setupInput();
  setupMic();
  sendBtn.disabled = true;
  // 少し待ってから挨拶
  setTimeout(() => sendOpeningMessage(), 800);
});

// ===== Opening =====
function sendOpeningMessage() {
  conversationHistory.push({ role: "model", content: CONFIG.OPENING_MESSAGE });
  appendMessage("ai", CONFIG.OPENING_MESSAGE);
  speak(CONFIG.OPENING_MESSAGE);
  setInputEnabled(true);
}

// ===== Send User Message =====
async function sendMessage() {
  const text = textInput.value.trim();
  if (!text || isProcessing) return;

  textInput.value = "";
  autoResizeTextarea();
  sendBtn.disabled = true;
  isProcessing = true;
  setInputEnabled(false);

  turnCount++;
  updateTurnCounter();

  conversationHistory.push({ role: "user", content: text });
  appendMessage("user", text);

  // Show typing
  const typingId = showTyping();

  try {
    let aiReply;

    if (turnCount >= CONFIG.MAX_TURNS) {
      // 最終ターン: 固定終了メッセージ + サマリー依頼
      removeTyping(typingId);
      aiReply = CONFIG.CLOSING_MESSAGE;
      conversationHistory.push({ role: "model", content: aiReply });
      appendMessage("ai", aiReply);
      speak(aiReply, () => {
        // 喋り終わったら終了処理
        finalizeSession();
      });
    } else {
      // 通常ターン: GASへ送信
      const res = await callGAS({
        action: "chat",
        history: conversationHistory,
        turn: turnCount,
      });

      removeTyping(typingId);
      aiReply = res.reply || "（返答の取得に失敗しました）";
      conversationHistory.push({ role: "model", content: aiReply });
      appendMessage("ai", aiReply);
      speak(aiReply);
      setInputEnabled(true);
      isProcessing = false;
    }

  } catch (err) {
    removeTyping(typingId);
    showToast("通信エラーが発生しました。再試行してください。");
    console.error(err);
    setInputEnabled(true);
    isProcessing = false;
    turnCount--; // rollback
    updateTurnCounter();
    conversationHistory.pop(); // rollback
  }
}

// ===== Finalize (Summary + Sheet + Mail) =====
async function finalizeSession() {
  setAvatarStatus("集計中...");
  try {
    await callGAS({
      action: "finalize",
      history: conversationHistory,
    });
  } catch (e) {
    console.warn("finalize error:", e);
  }
  showEndScreen();
}

// ===== GAS Call =====
async function callGAS(payload) {
  const res = await fetch(CONFIG.GAS_URL, {
    method: "POST",
    headers: { "Content-Type": "text/plain" }, // GAS CORS対策
    body: JSON.stringify(payload),
    redirect: "follow",
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  return await res.json();
}

// ===== DOM Helpers =====
function appendMessage(role, text) {
  const div = document.createElement("div");
  div.className = `msg ${role}`;

  const avatarDiv = document.createElement("div");
  avatarDiv.className = "msg-avatar";
  avatarDiv.textContent = role === "ai" ? "🤖" : "👤";

  const bubble = document.createElement("div");
  bubble.className = "bubble";
  bubble.textContent = text;

  div.appendChild(avatarDiv);
  div.appendChild(bubble);
  chatWindow.appendChild(div);
  chatWindow.scrollTop = chatWindow.scrollHeight;
}

function showTyping() {
  const id = "typing-" + Date.now();
  const div = document.createElement("div");
  div.className = "msg ai"; div.id = id;
  div.innerHTML = `
    <div class="msg-avatar">🤖</div>
    <div class="bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>
  `;
  chatWindow.appendChild(div);
  chatWindow.scrollTop = chatWindow.scrollHeight;
  setAvatarStatus("考え中...");
  return id;
}

function removeTyping(id) {
  const el = document.getElementById(id);
  if (el) el.remove();
}

function updateTurnCounter() {
  turnNum.textContent = turnCount;
}

function setInputEnabled(enabled) {
  textInput.disabled = !enabled;
  micBtn.disabled = !enabled;
  if (!enabled) {
    sendBtn.disabled = true;
  } else {
    sendBtn.disabled = !textInput.value.trim();
  }
}

function setAvatarStatus(text) {
  avatarStatus.textContent = text;
}

function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add("show");
  setTimeout(() => toast.classList.remove("show"), 3500);
}

function showEndScreen() {
  inputArea.style.display = "none";
  chatWindow.style.display = "none";
  endScreen.classList.add("visible");
  setAvatarStatus("セッション終了");
}

// ===== Input Setup =====
function setupInput() {
  textInput.addEventListener("input", () => {
    autoResizeTextarea();
    sendBtn.disabled = !textInput.value.trim() || isProcessing;
  });

  textInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      if (!sendBtn.disabled) sendMessage();
    }
  });

  sendBtn.addEventListener("click", sendMessage);
}

function autoResizeTextarea() {
  textInput.style.height = "auto";
  textInput.style.height = Math.min(textInput.scrollHeight, 120) + "px";
}

// ===== Web Speech API - TTS =====
function speak(text, onEnd) {
  if (!window.speechSynthesis) {
    if (onEnd) onEnd();
    return;
  }
  window.speechSynthesis.cancel();

  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = "ja-JP";
  utter.rate = 1.05;
  utter.pitch = 1.1;

  // 日本語音声を優先選択
  const voices = window.speechSynthesis.getVoices();
  const jaVoice = voices.find(v => v.lang.startsWith("ja"));
  if (jaVoice) utter.voice = jaVoice;

  utter.onstart = () => {
    avatarFrame.classList.add("speaking");
    setAvatarStatus("話し中...");
  };
  utter.onend = () => {
    avatarFrame.classList.remove("speaking");
    setAvatarStatus("待機中...");
    if (onEnd) onEnd();
  };
  utter.onerror = () => {
    avatarFrame.classList.remove("speaking");
    setAvatarStatus("待機中...");
    if (onEnd) onEnd();
  };

  window.speechSynthesis.speak(utter);
}

// ===== Web Speech API - STT =====
function setupMic() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    micBtn.title = "このブラウザは音声認識に対応していません";
    micBtn.disabled = true;
    return;
  }

  recognition = new SpeechRecognition();
  recognition.lang = "ja-JP";
  recognition.interimResults = true;
  recognition.continuous = false;

  recognition.onresult = (e) => {
    let interim = "";
    let final = "";
    for (let i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) final += e.results[i][0].transcript;
      else interim += e.results[i][0].transcript;
    }
    textInput.value = final || interim;
    autoResizeTextarea();
    sendBtn.disabled = !textInput.value.trim();
  };

  recognition.onend = () => {
    isRecording = false;
    micBtn.classList.remove("recording");
    setAvatarStatus("待機中...");
  };

  recognition.onerror = (e) => {
    isRecording = false;
    micBtn.classList.remove("recording");
    if (e.error !== "aborted") showToast("音声認識エラー: " + e.error);
  };

  micBtn.addEventListener("click", () => {
    if (isRecording) {
      recognition.stop();
    } else {
      window.speechSynthesis.cancel();
      try {
        recognition.start();
        isRecording = true;
        micBtn.classList.add("recording");
        setAvatarStatus("聞いています...");
      } catch (e) {
        showToast("マイクの起動に失敗しました");
      }
    }
  });
}

// ===== Voices load (async) =====
if (window.speechSynthesis) {
  window.speechSynthesis.onvoiceschanged = () => {
    window.speechSynthesis.getVoices(); // prime
  };
}
</script>
</body>
</html>
